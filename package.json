{
  "name": "finda.city",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@types/express": "^5.0.6"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "discord-logify": "^0.2.1",
    "express": "^5.2.1",
    "ioredis": "^5.9.2",
    "maxmind": "^5.0.5",
    "mongoose": "^9.1.6",
    "rate-limiter-flexible": "^9.1.0",
    "redis": "^5.10.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development bun run --watch ./src/index.ts",
    "prod": "NODE_ENV=production bun run ./src/index.ts",
    "pm2:start": "NODE_ENV=production pm2 start bun --name findaCity -- run src/index.ts",
    "start": "bun run src/index.ts",
    "pm2:rs": "pm2 restart findaCity --update-env",
    "pm2:stop": "pm2 delete findaCity"
  }
}
